# HAPSIC Secrets Template
# Copy this file to secrets.yaml and fill in your values.
# DO NOT commit secrets.yaml to version control.

wifi_ssid: "Your_IoT_SSID"
wifi_password: "Your_IoT_Password"
api_encryption_key: "GENERATE_WITH_esphome_compile"
ota_password: "SuperSecureOTAPassword"

# MQTT Broker — used by ESPHome firmware (stamplc.yaml) for telemetry publishing,
# and by dev scripts (read_mqtt_diff.py, test_harness.py) for live auditing.
#
# NOTE: The Python Digital Twin (hapsic_controller.py) does NOT connect to MQTT
# directly. It calls HA's mqtt.publish service via AppDaemon's HASS plugin.
# The broker address for the Digital Twin is configured in AppDaemon's
# appdaemon.yaml MQTT plugin section on the HA server, not here.
mqtt_broker: "YOUR_MQTT_BROKER_IP"
mqtt_username: "hapsic_plc"
mqtt_password: "mqtt_password"
